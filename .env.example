# Copy to .env.local for local development. Never commit real secrets.

# ─── Site ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Supabase ────────────────────────────────────────────────────────────
# From `supabase start` output, or your hosted project dashboard.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Direct Postgres URL for Drizzle. Local Supabase uses port 54322.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DIRECT_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ─── Stripe ──────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_GROWTH_ANNUAL=
STRIPE_PRICE_ENTERPRISE_MONTHLY=
STRIPE_PRICE_ENTERPRISE_ANNUAL=

# ─── Checkr (background checks, MVP scope) ────────────────────────────────
# Agency-paid, per-finalist. Wire during the background-check vertical slice.
CHECKR_API_KEY=
CHECKR_WEBHOOK_SECRET=

# ─── Resend (transactional email) ─────────────────────────────────────────
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

# ─── OpenAI (Phase 2: AI matching embeddings) ─────────────────────────────
OPENAI_API_KEY=

# ─── Analytics (optional) ─────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
